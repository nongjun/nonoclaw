# Cursor Agent CLI
CURSOR_API_KEY=key_your_cursor_api_key_here

# 模型 (可选 / Optional: opus-4.6-thinking, sonnet-4, auto, etc.)
CURSOR_MODEL=opus-4.6-thinking

# ── IM 渠道（至少配置一个）──────────────────────────

# 飞书 Bot（长连接模式，无需公网地址）
# Feishu/Lark Bot (WebSocket long connection, no public URL needed)
FEISHU_APP_ID=cli_your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 钉钉 Bot（Stream 模式，无需公网地址）
# DingTalk Bot (Stream mode, no public URL needed)
# 在钉钉开发者后台创建企业内部应用 → 应用能力 → 机器人 → 选择 Stream 模式
# https://open.dingtalk.com/document/orgapp/the-creation-and-installation-of-the-application-robot-in-the
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# Agent ID（可选，部分 OpenAPI 需要）
DINGTALK_AGENT_ID=

# ── 可选服务 ────────────────────────────────────────

# 火山引擎语音识别 / Volcengine Speech Recognition (optional)
# https://www.volcengine.com/docs/6561/1354869
VOLC_STT_APP_ID=
VOLC_STT_ACCESS_TOKEN=

# 火山引擎向量嵌入 / Volcengine Embedding for Memory Search (optional)
VOLC_EMBEDDING_API_KEY=
VOLC_EMBEDDING_MODEL=doubao-embedding-vision-250615
